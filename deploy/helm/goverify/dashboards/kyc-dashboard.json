{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "targets": [{ "expr": "sum(goverify_kyc_enrollments_total)", "refId": "A" }],
      "title": "Total Enrollments",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "targets": [{ "expr": "sum(goverify_kyc_verifications_total)", "refId": "A" }],
      "title": "Total Verifications",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "targets": [{ "expr": "sum(rate(goverify_kyc_verifications_total{status=\"error\"}[5m])) / sum(rate(goverify_kyc_verifications_total[5m])) * 100", "refId": "A" }],
      "title": "KYC Error Rate",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(goverify_kyc_verify_latency_ms_bucket[1m])) by (le))", "refId": "A" }],
      "title": "Verify Latency (p95)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"kyc-ai\"}[1m])) by (le)) * 1000", "refId": "A" }],
      "title": "AI Latency (p95)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "targets": [{ "expr": "goverify_kafka_consumer_lag_ms{quantile=\"0.9\"}", "refId": "A" }],
      "title": "Kafka Lag (p90)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(goverify_kyc_verify_latency_ms_bucket[5m])) by (le))", "legendFormat": "KYC p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(goverify_kyc_verify_latency_ms_bucket[5m])) by (le))", "legendFormat": "KYC p95", "refId": "B" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"kyc-ai\"}[5m])) by (le)) * 1000", "legendFormat": "AI p95", "refId": "C" }
      ],
      "title": "Latency Comparison",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sum(rate(goverify_http_requests_total[1m]))", "legendFormat": "API Req/s", "refId": "A" },
        { "expr": "sum(rate(http_requests_total{job=\"kyc-ai\"}[1m]))", "legendFormat": "AI Req/s", "refId": "B" },
        { "expr": "sum(rate(goverify_kyc_verifications_total[1m]))", "legendFormat": "KYC Matches/s", "refId": "C" }
      ],
      "title": "Throughput (TPS)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "id": 9,
      "options": {
        "displayLabels": ["percent"],
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut"
      },
      "targets": [{ "expr": "sum by (status) (goverify_kyc_verifications_total)", "legendFormat": "{{status}}", "refId": "A" }],
      "title": "Verification Outcomes",
      "type": "piechart"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 12 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "goverify_kafka_consumer_lag_ms{quantile=\"0.9\"}", "legendFormat": "Kafka Lag p90", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(goverify_vectordb_search_latency_ms_bucket[5m])) by (le))", "legendFormat": "Milvus Search p95", "refId": "B" }
      ],
      "title": "Infrastructure Latency",
      "type": "timeseries"
    },
    {
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "id": 11,
      "options": {
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [{ "expr": "{job=~\"$job\", pod=~\"$pod\"}", "refId": "A" }],
      "title": "Service Logs (Loki)",
      "type": "logs"
    }
  ],
  "templating": {
    "list": [
      {
        "allValue": ".+",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": "Prometheus",
        "hide": 0,
        "includeAll": true,
        "name": "job",
        "options": [],
        "query": "label_values(up, job)",
        "refresh": 1,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".+",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": "Prometheus",
        "hide": 0,
        "includeAll": true,
        "name": "pod",
        "options": [],
        "query": "label_values(up{job=~\"$job\"}, pod)",
        "refresh": 1,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "refresh": "5s",
  "schemaVersion": 30,
  "style": "dark",
  "time": { "from": "now-15m", "to": "now" },
  "title": "KYC Engine - Golden Signals",
  "uid": "kyc_performance",
  "version": 5
}
