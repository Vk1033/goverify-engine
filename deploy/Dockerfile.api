FROM golang:1.26-bookworm AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -tags noonnx -ldflags="-s -w" -o /kyc-api cmd/kyc-api/main.go

FROM debian:bookworm-slim
WORKDIR /app
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /kyc-api /kyc-api

EXPOSE 8080
ENTRYPOINT ["/kyc-api"]
