# --- Stage 1: Builder ---
FROM golang:1.23-bookworm AS builder
WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /kyc-worker cmd/kyc-worker/main.go

# --- Stage 2: Final Image ---
FROM debian:bookworm-slim
WORKDIR /app

RUN apt-get update && apt-get install -y ca-certificates curl && rm -rf /var/lib/apt/lists/*

COPY --from=builder /kyc-worker /kyc-worker

EXPOSE 9090
ENTRYPOINT ["/kyc-worker"]
